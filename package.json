{
  "name": "rtm",
  "version": "0.1.0",
  "private": true,
  "description": "A CLI tool for Remember The Milk task management",
  "keywords": [
    "cli",
    "productivity",
    "remember-the-milk",
    "rtm",
    "task-management",
    "todo"
  ],
  "homepage": "https://github.com/emmertarmin/rtm-cli#readme",
  "bugs": {
    "url": "https://github.com/emmertarmin/rtm-cli/issues"
  },
  "license": "MIT",
  "author": "Armin Emmert <emmertarmin@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emmertarmin/rtm-cli.git"
  },
  "bin": {
    "rtm": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "prebuild": "bun -e \"import p from './package.json' with {type:'json'}; await Bun.write('src/version.ts', 'export const VERSION = \\\"' + p.version + '\\\";\\n')\"",
    "build": "bun build index.ts --outdir ./dist --target node && tsc --emitDeclarationOnly",
    "tsc": "tsc --noEmit --emitDeclarationOnly false",
    "prepublishOnly": "npm run build",
    "start": "bun run index.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.3.10",
    "typescript": "^5",
    "undici-types": "^7.18.2"
  },
  "engines": {
    "node": ">=18"
  }
}
